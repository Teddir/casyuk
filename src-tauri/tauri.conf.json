{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "casyuk",
  "version": "0.1.0",
  "identifier": "com.mac.casyuk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "casyuk",
        "width": 800,
        "height": 600,
        "label": "main"
      },
      {
        "title": "CasYuk Alert",
        "label": "alert",
        "width": 800,
        "height": 600,
        "transparent": true,
        "decorations": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "url": "/?window=alert"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
